<Window x:Class="Any2GSX.UI.Views.Automation.VariableCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Any2GSX.UI.Views.Automation"
        d:DataContext="{d:DesignInstance Type=local:ModelVariables}"
        mc:Ignorable="d"
        Title="Variable Checker" MinHeight="256" MinWidth="384" MaxWidth="780" WindowStyle="ToolWindow" ResizeMode="NoResize" SizeToContent="WidthAndHeight">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="VariableInput" TargetType="TextBox" BasedOn="{StaticResource TextBoxLeft}">
                <Setter Property="Margin" Value="6,0,6,6"/>
                <Setter Property="MinHeight" Value="24"/>
            </Style>
            <Style x:Key="VariableLabel" TargetType="TextBlock" BasedOn="{StaticResource TextBlockDefault}">
                <Setter Property="Margin" Value="6,6,6,0"/>
                <Setter  Property="FontWeight" Value="DemiBold"/>
                <Setter Property="MinHeight" Value="24"/>
            </Style>
            <Style x:Key="VariableUnit" TargetType="TextBlock" BasedOn="{StaticResource TextBlockDefault}">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="MinWidth" Value="48"/>
                <Setter Property="Margin" Value="6,6,6,6"/>
                <Setter Property="MinHeight" Value="24"/>
            </Style>
            <Style TargetType="ToggleButton" x:Key="QueryButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                <Setter Property="Width" Value="24"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="Margin" Value="8,0,6,6"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Column="0" Grid.Row="0" Style="{StaticResource GroupBoxDefault}">
            <GroupBox.Header>Query Variable</GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" Style="{StaticResource VariableLabel}">
                    Name
                </TextBlock>
                <TextBlock Grid.Column="1" Grid.Row="0" Style="{StaticResource VariableLabel}">
                    Unit
                </TextBlock>
                <TextBlock Grid.Column="3" Grid.Row="0" Style="{StaticResource VariableLabel}">
                    Value
                </TextBlock>

                <TextBox Grid.Column="0" Grid.Row="1" Name="InputVariableName" Text="{Binding VariableName}" IsEnabled="{Binding IsEditAllowed}" IsHitTestVisible="{Binding IsEditAllowed}" MinWidth="240" Style="{StaticResource VariableInput}"/>
                <TextBox Grid.Column="1" Grid.Row="1" Name="InputVariableUnit" Text="{Binding VariableUnit}" IsEnabled="{Binding IsEditAllowed}" IsHitTestVisible="{Binding IsEditAllowed}" MinWidth="160" Style="{StaticResource VariableInput}"/>
                <TextBlock Grid.Column="3" Grid.Row="1" Text="{Binding VariableValue}" MinWidth="96" Style="{StaticResource VariableUnit}"/>

                <ToggleButton Grid.Column="2" Grid.Row="1" Command="{Binding MonitorVariableCommand}" Style="{StaticResource QueryButton}">
                    <Image Source="../../Icons/binoculars.png" Style="{StaticResource ImgSquareSmall}"/>
                </ToggleButton>

                <TextBlock Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="2" Margin="6,4,4,4" Style="{StaticResource TextBlockDefault}">
                    <Italic>        
                        <Bold>Note:</Bold> L-Vars need to prefixed with 'L:'
                    </Italic>
                </TextBlock>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Column="0" Grid.Row="1" Style="{StaticResource GroupBoxDefault}">
            <GroupBox.Header>Profile Variables</GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Vertical" Name="PanelProfileVariables" Margin="4,0,0,0"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
