<UserControl x:Class="Any2GSX.UI.Views.Automation.ControlLoadsheetNotifications"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Any2GSX.UI.Views.Automation"
             d:DataContext="{d:DesignInstance Type=local:ModelAutomation}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Column="0" Grid.Row="0" Margin="8,0,8,8" Style="{StaticResource GroupBoxDefault}">
            <GroupBox.Header>Loadsheet &amp; Notifications</GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Column="0" Grid.Row="0" Margin="4,4,0,0" MaxWidth="620" TextWrapping="WrapWithOverflow">
                    <Italic>
                        <Bold>Note:</Bold> The Final Delay is primarily a Timer to trigger other Events in the App.
                        <LineBreak/>
                        An actual Loadsheet is only send when the Aircraft Plugin implements that Function.
                    </Italic>
                </TextBlock>

                <Grid Grid.Column="0" Grid.Row="1" Margin="6,6,6,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Margin="0,0,0,6" Style="{StaticResource TextBlockDefault}" ToolTip="Minimum Delay in Seconds after Departure Services completed before the Final Loadsheet is considered as received (for other Settings waiting on the Final).">
                            Final LS Delay Minimum
                    </TextBlock>
                    <TextBox Grid.Column="1" Grid.Row="0" Name="InputFinalMinimum" Margin="8,0,0,6" Style="{StaticResource TextBoxCentered}" ToolTip="Minimum Delay in Seconds after Departure Services completed before the Final Loadsheet is considered as received (for other Settings waiting on the Final)."/>
                    <TextBlock Grid.Column="2" Grid.Row="0" Margin="2,0,0,6" Style="{StaticResource TextBlockDefault}">s</TextBlock>

                    <TextBlock Grid.Column="0" Grid.Row="1" Style="{StaticResource TextBlockDefault}" ToolTip="Maximum Delay in Seconds after Departure Services completed before the Final Loadsheet is considered as received (for other Settings waiting on the Final).">
                        Final LS Delay Maximum
                    </TextBlock>
                    <TextBox Grid.Column="1" Grid.Row="1" Name="InputFinalMaximum" Margin="8,0,0,0" Style="{StaticResource TextBoxCentered}" ToolTip="Maximum Delay in Seconds after Departure Services completed before the Final Loadsheet is considered as received (for other Settings waiting on the Final)."/>
                    <TextBlock Grid.Column="2" Grid.Row="1" Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}">s</TextBlock>
                </Grid>

                <CheckBox Grid.Column="0" Grid.Row="2" IsChecked="{Binding NotifyPrepFinished}" Margin="6,6,6,6" Style="{StaticResource CheckBoxSettingItem}" Visibility="{Binding HasNotificationPrep, Converter={StaticResource BoolVisibilityConverter}}"
                          ToolTip="The App can send a Notification/Signal (i.e. some 'Ding' Sound) to the Cockpit, when the App is ready to start the Departure Phase (Reposition finished, Jetway/Stairs called)&#x0a;(Only when the Aircraft Plugin implements that Notification!)">
                    <TextBlock>Notify Cockpit when ready for <Underline>Departure</Underline> Services</TextBlock>
                </CheckBox>
                <CheckBox Grid.Column="0" Grid.Row="3" IsChecked="{Binding NotifyFinalReceived}" Margin="6,6,6,6" Style="{StaticResource CheckBoxSettingItem}" Visibility="{Binding HasNotificationFinal, Converter={StaticResource BoolVisibilityConverter}}"
                          ToolTip="The App can send a Notification/Signal (i.e. some 'Ding' Sound) to the Cockpit, when the Final Loadsheet Delay has ended.&#x0a;(Only when the Aircraft Plugin implements that Notification!)">
                    <TextBlock>Notify Cockpit when <Underline>Loadsheet</Underline> is transmitted</TextBlock>
                </CheckBox>
                <CheckBox Grid.Column="0" Grid.Row="4" IsChecked="{Binding NotifyChocksPlaced}" Margin="6,6,6,6" Style="{StaticResource CheckBoxSettingItem}" Visibility="{Binding HasNotificationChocks, Converter={StaticResource BoolVisibilityConverter}}"
                          ToolTip="The App can send a Notification/Signal (i.e. some 'Ding' Sound) to the Cockpit, when the Chocks have been placed on Arrival.&#x0a;(Only when the Aircraft Plugin implements that Notification!)">
                    <TextBlock>Notify Cockpit when <Underline>Chocks</Underline> are placed</TextBlock>
                </CheckBox>
                <CheckBox Grid.Column="0" Grid.Row="5" IsChecked="{Binding NotifyTurnReady}" Margin="6,6,6,6" Style="{StaticResource CheckBoxSettingItem}"  Visibility="{Binding HasNotificationTurn, Converter={StaticResource BoolVisibilityConverter}}"
                          ToolTip="The App can send a Notification/Signal (i.e. some 'Ding' Sound) to the Cockpit, when the App is ready to import the next Flightplan (and can start over in the Departure Phase).&#x0a;(Only when the Aircraft Plugin implements that Notification!)">
                    <TextBlock>Notify Cockpit when ready for <Underline>Turnaround</Underline></TextBlock>
                </CheckBox>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
