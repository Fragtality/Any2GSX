<UserControl x:Class="Any2GSX.UI.Views.Automation.ViewAutomation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Any2GSX.UI.Views.Automation"
             d:DataContext="{d:DesignInstance Type=local:ModelAutomation}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid HorizontalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ContentControl Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Name="ViewProfileSelector" Margin="10,6,6,6" ToolTip="Select the active Profile."/>

        <ListView Grid.Column="0" Grid.Row="1" Margin="12,4,12,12" MinWidth="164" MinHeight="148" Name="SelectorSettingGroup" SelectedValuePath="Key" BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border ToolTip="{Binding Value.ToolTip}">
                        <StackPanel Orientation="Horizontal" Margin="2">
                            <Image Source="../../Icons/cursor.png" Width="16" Height="16"/>
                            <Label Content="{Binding Value.Tag}" FontSize="12" FontWeight="DemiBold"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ContentControl Grid.Column="1" Grid.Row="1" Name="ViewSettingGroup" Margin="2,6,6,6"/>
    </Grid>
</UserControl>

    