<UserControl x:Class="Any2GSX.UI.Views.ControlProfileSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Any2GSX.UI.Views"
             xmlns:app="clr-namespace:Any2GSX"
             d:DataContext="{d:DesignInstance Type=local:ModelSelector}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../StyleResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid HorizontalAlignment="Stretch" Name="GridProfile">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Style="{StaticResource TextBlockDefault}" MinWidth="48" Padding="4" FontWeight="DemiBold" FontSize="14">Profile:</TextBlock>
        <TextBlock Grid.Column="1" Grid.Row="0" Name="ProfileDisplay" Text="{Binding Source={x:Static app:AppService.Instance}, Path=ProfileName}" Style="{StaticResource TextBlockDefault}" MinWidth="132" Padding="4" FontWeight="DemiBold" FontSize="14"/>
        <ComboBox Grid.Column="1" Grid.Row="0" Name="SelectorProfiles" DisplayMemberPath="Name" IsEnabled="{Binding IsSessionStopped}" IsHitTestVisible="{Binding IsSessionStopped}" Style="{StaticResource ComboBoxDefault}" MinWidth="132" Padding="4" FontWeight="DemiBold" FontSize="14" Visibility="Hidden"/>
    </Grid>
</UserControl>
